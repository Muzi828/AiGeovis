**/.idea/
**/.vscode/
**/*.swp
**/.DS_Store
**/Thumbs.db

# Logs / temp
**/*.log
**/tmp/
**/temp/

# Local deploy packaging (built by deploy/pack-release.ps1)
deploy/release/
